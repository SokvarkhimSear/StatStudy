rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isTeacher() {
      return isSignedIn() && getUserData().role == 'teacher';
    }

    function isStudent() {
      return isSignedIn() && getUserData().role == 'student';
    }

    // Class Codes for Login Validation
    match /classCodes/{codeId} {
      allow read: if true; // anyone can check if a code is valid for sign-in
    }

    // User Profiles
    match /users/{userId} {
      allow get: if true; // allow checking if user document exists for sign in
      allow list: if isSignedIn();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isSignedIn() && request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'code']);
    }

    // Homework Assignments
    match /homeworks/{homeworkId} {
      allow read: if isSignedIn() && (isTeacher() || resource.data.isPublished == true);
      allow create: if isTeacher();
      allow update: if isTeacher() && existing().teacherId == request.auth.uid;
      allow delete: if isTeacher() && existing().teacherId == request.auth.uid;

      // Submissions
      match /submissions/{studentId} {
        allow read: if isTeacher() || (isStudent() && request.auth.uid == studentId);
        allow create: if isStudent() && request.auth.uid == studentId && incoming().studentId == request.auth.uid;
        allow update: if isTeacher(); // Teachers grading or changing status
      }
    }

    // Quiz Results
    match /users/{userId}/quizResults/{resultId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow create: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
